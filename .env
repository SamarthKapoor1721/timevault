# ─────────────────────────────────────────────────────────────
# FRONTEND ENVIRONMENT VARIABLES
# ─────────────────────────────────────────────────────────────
# Copy this to .env and fill in your values
# All variables MUST start with VITE_ to be accessible in React
# ─────────────────────────────────────────────────────────────

# Your deployed contract address (from deploy.js output)
VITE_CONTRACT_ADDRESS=0x50D80Dfb7C4292ac822bF347F07Cc7C35D007517

# Chain ID:
#   31337 = Hardhat local network
#   11155111 = Sepolia testnet
#   1 = Ethereum mainnet
VITE_CHAIN_ID=11155111

# Pinata API credentials — for uploading messages to IPFS
# Get them at: https://app.pinata.cloud/keys
# Create a new API key with "pinFileToIPFS" permission
VITE_PINATA_API_KEY=b24c6dbbb02e7fc76ff0
VITE_PINATA_SECRET_KEY=933627cd1e757770b3318416c6fe40c5caeffbbf8bb7b28928dd7ebe6ff3b978

# IPFS Gateway — for fetching stored messages
# Pinata's gateway: https://gateway.pinata.cloud/ipfs/
# Public gateway:   https://ipfs.io/ipfs/
VITE_IPFS_GATEWAY=https://gateway.pinata.cloud/ipfs/
